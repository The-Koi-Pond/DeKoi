{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeKoi",
  "version": "0.1.0",
  "identifier": "com.xelvanas.dekoi",
  "build": {
    "beforeDevCommand": "pnpm dev:tauri-frontend",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeKoi",
        "label": "main",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}

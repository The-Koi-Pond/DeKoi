{
  "name": "dekoi",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri-frontend": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "docs:dev": "vite docs/developer --host 127.0.0.1 --port 4174",
    "runtime:fixture": "node scripts/remote-runtime-fixture.mjs",
    "check:desktop-contracts": "node scripts/check-desktop-contracts.mjs",
    "check:storage-contracts": "node scripts/check-storage-contracts.mjs",
    "check:runtime-contracts": "node scripts/check-runtime-contracts.mjs",
    "check:frontend-boundaries": "node scripts/check-frontend-boundaries.mjs",
    "check:bunny-review": "node .github/bunny-review/check-bunny-review.mjs && node .github/bunny-review/run_guidance_check.mjs --self-test && node .github/bunny-review/run_guidance_check.mjs",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check": "pnpm check:desktop-contracts && pnpm check:storage-contracts && pnpm check:runtime-contracts && pnpm check:frontend-boundaries && pnpm check:bunny-review && pnpm build && pnpm lint && pnpm check:rust",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
